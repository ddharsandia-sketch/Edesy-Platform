generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  plan      String   @default("free")  // "free" | "pro" | "enterprise"
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  paypalSubscriptionId String?  @unique
  paypalPayerId        String?  @unique
  planTier             String   @default("free")
  planExpiresAt        DateTime?
  createdAt DateTime @default(now())
  agents    Agent[]
  calls     Call[]
  apiKeys   ApiKey[]
  webhooks  Webhook[]
  phoneNumbers PhoneNumber[]
  campaigns Campaign[]
}

model Agent {
  id              String   @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  name            String
  personaPrompt   String   @db.Text
  language        String   @default("en")  // "en" | "hi" | "ta" | "te" | "bn" | "ml"
  voiceProvider   String   @default("cartesia")  // "cartesia" | "elevenlabs" | "azure"
  voiceId         String   @default("71a7ad14-091c-4e8e-a314-022ece01c121")
  sttProvider     String   @default("deepgram")   // "deepgram" | "google_chirp" | "sarvam"
  llmModel        String   @default("gpt-4o-mini")
  useGeminiLive   Boolean  @default(false)  // Native S2S ultra-low latency mode
  greetingAudio   Bytes?   // Prefetched greeting audio bytes stored in DB
  industry        String   @default("general")   // For compliance guard
  handoffPhone    String?                         // Transfer target on violations
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  calls           Call[]
  knowledgeDocs   KnowledgeDoc[]
  phoneNumbers    PhoneNumber[]
  campaigns       Campaign[]
}

model KnowledgeDoc {
  id          String   @id @default(uuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id])
  fileName    String
  fileType    String   // "pdf" | "url" | "text"
  content     String   @db.Text
  embedded    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model PhoneNumber {
  id          String   @id @default(uuid())
  number      String   @unique   // E.164 format: +14155551234
  provider    String   @default("twilio")
  agentId     String
  workspaceId String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  region      String?  // "us" | "india" | "global" - made optional to not break existing data
  createdAt   DateTime @default(now())
}

model Call {
  id             String   @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id])
  callerNumber   String
  direction      String   // "inbound" | "outbound"
  status         String   @default("dialing")
  // Status options: "dialing" | "connected" | "handling_objection" | "extracting_data" | "completed" | "failed" | "transferred"
  transcript     Json     @default("[]")
  sentiment      Float?   // -1.0 to 1.0
  duration       Int?     // seconds
  costUsd        Float?
  artifact       Json?    // Structured data extracted from call (booking, order, complaint)
  supervisorNotes Json    @default("[]")  // All supervisor injections logged
  liveKitRoomId  String?
  twilioCallSid   String?   // Maps Twilio calls to our DB records
  startTime      DateTime @default(now())
  endTime        DateTime?

  @@index([workspaceId, startTime])
  @@index([twilioCallSid])
  @@index([agentId, startTime])
}

model ApiKey {
  id          String   @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  key         String   @unique  // Format: "vak_" + random 32 chars
  name        String
  createdAt   DateTime @default(now())
  lastUsed    DateTime?
}

model Webhook {
  id          String   @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  url         String
  secret      String?  // For HMAC signatures
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Campaign {
  id             String   @id @default(cuid())
  workspaceId    String
  agentId        String
  name           String
  status         String   @default("draft")
  // "draft" | "scheduled" | "running" | "paused" | "completed" | "failed"
  callsPerMinute Int      @default(2)
  maxRetries     Int      @default(1)
  scheduledAt    DateTime?
  completedAt    DateTime?
  totalContacts  Int      @default(0)
  calledCount    Int      @default(0)
  answeredCount  Int      @default(0)
  convertedCount Int      @default(0)
  createdAt      DateTime @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  agent          Agent    @relation(fields: [agentId], references: [id])
  contacts       CampaignContact[]
}

model CampaignContact {
  id          String    @id @default(cuid())
  campaignId  String
  phoneNumber String
  name        String?
  metadata    Json?
  status      String    @default("pending")
  // "pending" | "calling" | "answered" | "failed" | "converted" | "do_not_call"
  callId      String?
  attempts    Int       @default(0)
  lastAttempt DateTime?
  createdAt   DateTime  @default(now())
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@index([phoneNumber])
}
