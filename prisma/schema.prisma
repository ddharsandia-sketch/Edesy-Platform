generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id                   String               @id @default(uuid())
  name                 String
  ownerId              String
  plan                 String               @default("free")
  createdAt            DateTime             @default(now())
  planExpiresAt        DateTime?
  planTier             String               @default("free")
  stripeCustomerId     String?              @unique
  stripeSubscriptionId String?              @unique
  onboardingComplete   Boolean              @default(false)
  paypalPayerId        String?              @unique
  paypalSubscriptionId String?              @unique
  agentsLimit          Int                  @default(3)
  anthropicApiKey      String?
  callsLimit           Int                  @default(1000)
  cartesiaApiKey       String?
  cerebrasApiKey       String?
  deepgramApiKey       String?
  elevenLabsApiKey     String?
  exotelApiKey         String?
  exotelSid            String?
  geminiApiKey         String?
  groqApiKey           String?
  isUnlimited          Boolean              @default(false)
  minutesLimit         Int                  @default(500)
  openaiApiKey         String?
  sarvamApiKey         String?
  twilioAccountSid     String?
  twilioAuthToken      String?
  twilioPhoneNumber    String?
  activeTel            String?              @default("twilio")
  exotelToken          String?
  agents               Agent[]
  apiKeys              ApiKey[]
  calls                Call[]
  campaigns            Campaign[]
  integrations         Integration[]
  phoneNumbers         PhoneNumber[]
  providerCredentials  ProviderCredentials?
  webhooks             Webhook[]
  googleAccessToken    String?
  googleRefreshToken   String?
  googleTokenExpiry    DateTime?
  knowledgeDocuments   KnowledgeBaseDocument[]
}

model ProviderCredentials {
  id            String    @id @default(uuid())
  workspaceId   String    @unique
  openaiKey     String?
  groqKey       String?
  cerebrasKey   String?
  twilioSid     String?
  twilioToken   String?
  exotelSid     String?
  exotelKey     String?
  exotelToken   String?
  activeLlm     String    @default("openai")
  activeTel     String    @default("twilio")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  anthropicKey  String?
  cartesiaKey   String?
  deepgramKey   String?
  elevenlabsKey String?
  geminiKey     String?
  sarvamKey     String?
  googleKey     String?
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Agent {
  id               String         @id @default(uuid())
  workspaceId      String
  name             String
  personaPrompt    String
  language         String         @default("en")
  voiceProvider    String         @default("cartesia")
  voiceId          String         @default("71a7ad14-091c-4e8e-a314-022ece01c121")
  sttProvider      String         @default("deepgram")
  llmModel         String         @default("gpt-4o-mini")
  useGeminiLive    Boolean        @default(false)
  greetingAudio    Bytes?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  handoffPhone     String?
  industry         String         @default("general")
  templateId       String?
  extractionSchema Json?
  knowledgeBaseId  String?
  sttModel         String?
  telephonyProvider String  @default("twilio")
  phoneNumber      String?
  tierId           String?
  ttsLoudness      Float?         @default(1.0)
  ttsModel         String?
  ttsPace          Float?         @default(1.0)
  useCaseId        String?
  workspace        Workspace      @relation(fields: [workspaceId], references: [id])
  calls            Call[]
  campaigns        Campaign[]
  knowledgeDocs    KnowledgeDoc[]
  phoneNumbers     PhoneNumber[]
}

model KnowledgeDoc {
  id        String   @id @default(uuid())
  agentId   String
  fileName  String
  fileType  String
  content   String
  embedded  Boolean  @default(false)
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id])
}

model PhoneNumber {
  id          String    @id @default(uuid())
  agentId     String
  number      String    @unique
  provider    String    @default("twilio")
  region      String?
  createdAt   DateTime  @default(now())
  workspaceId String
  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Call {
  id              String    @id @default(uuid())
  workspaceId     String
  agentId         String
  callerNumber    String
  direction       String
  status          String    @default("dialing")
  transcript      Json      @default("[]")
  sentiment       Float?
  duration        Int?
  costUsd         Float?
  artifact        Json?
  supervisorNotes Json      @default("[]")
  liveKitRoomId   String?
  startTime       DateTime  @default(now())
  endTime         DateTime?
  twilioCallSid   String?
  agent           Agent     @relation(fields: [agentId], references: [id])
  workspace       Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, startTime])
  @@index([twilioCallSid])
  @@index([agentId, startTime])
}

model ApiKey {
  id          String    @id @default(uuid())
  workspaceId String
  key         String    @unique
  name        String
  createdAt   DateTime  @default(now())
  lastUsed    DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Webhook {
  id          String    @id @default(uuid())
  workspaceId String
  url         String
  secret      String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Campaign {
  id             String            @id @default(cuid())
  workspaceId    String
  agentId        String
  name           String
  status         String            @default("draft")
  callsPerMinute Int               @default(2)
  maxRetries     Int               @default(1)
  scheduledAt    DateTime?
  completedAt    DateTime?
  totalContacts  Int               @default(0)
  calledCount    Int               @default(0)
  answeredCount  Int               @default(0)
  convertedCount Int               @default(0)
  createdAt      DateTime          @default(now())
  agent          Agent             @relation(fields: [agentId], references: [id])
  workspace      Workspace         @relation(fields: [workspaceId], references: [id])
  contacts       CampaignContact[]
}

model AgentTemplate {
  id                String   @id @default(cuid())
  name              String
  category          String
  llmModel          String
  sttProvider       String
  ttsProvider       String
  voiceId           String
  telephonyProvider String
  language          String
  description       String
  isBuiltIn         Boolean  @default(true)
  createdAt         DateTime @default(now())
}

model Integration {
  id           String    @id @default(cuid())
  workspaceId  String
  type         String
  label        String
  apiKey       String
  config       Json?
  enabled      Boolean   @default(true)
  lastTestedAt DateTime?
  lastTestOk   Boolean?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model CampaignContact {
  id          String    @id @default(cuid())
  campaignId  String
  phoneNumber String
  name        String?
  metadata    Json?
  status      String    @default("pending")
  callId      String?
  attempts    Int       @default(0)
  lastAttempt DateTime?
  createdAt   DateTime  @default(now())
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@index([phoneNumber])
}

model KnowledgeBaseDocument {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  fileType    String
  sizeBytes   Int
  s3Key       String
  status      String   @default("pending")
  chunkCount  Int      @default(0)
  createdAt   DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
