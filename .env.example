# ============ DATABASE ============
DATABASE_URL=postgresql://voiceai:voiceai_secret@localhost:5432/voiceai_db

# ============ REDIS ============
REDIS_URL=redis://localhost:6379

# ============ QDRANT ============
QDRANT_URL=http://localhost:6333

# ============ AUTH (Supabase) ============
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
JWT_SECRET=a_random_64_character_string_you_generate

# ============ AI PROVIDERS ============
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=...
CARTESIA_API_KEY=...
ELEVENLABS_API_KEY=...
SARVAM_API_KEY=...
GOOGLE_GEMINI_API_KEY=...

# ============ TELEPHONY ============
TELEPHONY_PROVIDER=signalwire  # "twilio" | "signalwire" | "exotel"
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
SIGNALWIRE_PROJECT_ID=...
SIGNALWIRE_API_TOKEN=...
SIGNALWIRE_SPACE_URL=...
EXOTEL_API_KEY=...
EXOTEL_API_TOKEN=...
EXOTEL_ACCOUNT_SID=...

# ============ BILLING (PayPal) ============
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
PAYPAL_WEBHOOK_ID=...
PAYPAL_STARTER_PLAN_ID=...
PAYPAL_GROWTH_PLAN_ID=...
PAYPAL_ENTERPRISE_PLAN_ID=...

# ============ LIVEKIT ============
LIVEKIT_URL=wss://your-app.livekit.cloud
LIVEKIT_API_KEY=...
LIVEKIT_API_SECRET=...

# ============ APP ============
NODE_ENV=development
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTERNAL_API_KEY=dev-internal-key
